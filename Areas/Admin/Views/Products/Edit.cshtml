

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h1>CHỈNH SỬA</h1>

<h4>Sản phẩm</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form id="editProductForm" enctype="multipart/form-data">
            <div class="text-danger"></div>
            <input type="hidden" name="Id" id="Id" value='@ViewContext.RouteData.Values["id"]' />
            <div class="form-group flex-grow-1 mx-4">
                <div id="previewImages" class="d-flex flex-wrap gap-2 mb-3">
                    <!-- Images loaded from API -->
                </div>
                <label class="control-label">Hình ảnh (Chọn file mới để thay thế hoặc để trống giữ nguyên ảnh cũ)</label>
                <input type="file" name="images" id="imageUpload" class="form-control-file" onchange="previewFiles(event)" multiple />
            </div>

            <div class="form-group">
                <label class="control-label">Tên sản phẩm</label>
                <input name="Name" id="Name" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="control-label">Mô tả</label>
                <input name="Description" id="Description" class="form-control" />
            </div>
            <div class="form-group">
                <label class="control-label">Đơn giá</label>
                <input name="Price" id="Price" type="number" step="any" class="form-control" required />
            </div>
            <div class="form-group">
                <label>Trạng Thái</label>
                <select class="form-control" name="Status" id="Status" required>
                    <option value="1">Hoạt động</option>
                    <option value="2">Ngừng hoạt động</option>
                </select>
            </div>
            <div class="form-group">
                <label class="control-label">Sản phẩm theo loại</label>
                <select name="ProductTypeId" id="ProductTypeId" class="form-control" asp-items="ViewBag.ProductTypeId" required>
                </select>
            </div>
            <div class="form-group">
                <a asp-action="Index" class="btn btn-light">Trở về</a>
                <button type="button" onclick="submitEditForm()" class="btn btn-gradient-primary me-2">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@* <div>
    <a asp-action="Index">Back to List</a>
</div> *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            loadProductData();
        });

        function loadProductData() {
            var id = document.getElementById('Id').value;
            if (!id) return;

            $.ajax({
                url: '/api/products/' + id,
                type: 'GET',
                success: function (res) {
                    $('#Name').val(res.name);
                    $('#Description').val(res.description);
                    $('#Price').val(res.price);
                    $('#Status').val(res.status);
                    
                    // Note: ViewBag.ProductTypeId still render options from Server, but we set selected by JS:
                    $('#ProductTypeId').val(res.productTypeId);

                    // Load Images
                    var previewContainer = document.getElementById("previewImages");
                    previewContainer.innerHTML = "";
                    if (res.imageUrls && res.imageUrls.length > 0) {
                        res.imageUrls.forEach(function (url) {
                            const img = document.createElement("img");
                            img.src = '/contents/Images/Product/' + url;
                            img.style = "width: 200px; height: 200px; border-radius: 20px; margin-right: 10px;";
                            previewContainer.appendChild(img);
                        });
                    }
                },
                error: function (err) {
                    alert('Lỗi tải dữ liệu sản phẩm');
                }
            });
        }

        const previewFiles = (event) => {
            const files = event.target.files;
            const previewContainer = document.getElementById("previewImages");
            previewContainer.innerHTML = ""; // Xóa ảnh cũ

            Array.from(files).forEach(file => {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const img = document.createElement("img");
                    img.src = e.target.result;
                    img.style = "width: 200px; height: 200px; border-radius: 20px; margin-right: 10px;";
                    previewContainer.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        };

        function submitEditForm() {
            var form = document.getElementById('editProductForm');
            if(!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            var formData = new FormData(form);
            var id = document.getElementById('Id').value;

            $.ajax({
                url: '/api/products/' + id,
                type: 'PUT',
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {
                    alert("Cập nhật sản phẩm thành công!");
                    window.location.href = '/Admin/product'; // Redirect back
                },
                error: function (err) {
                    console.error('Error:', err);
                    if(err.responseJSON && err.responseJSON.message) {
                        alert("Lỗi: " + err.responseJSON.message);
                    } else {
                        alert("Có lỗi xảy ra khi sửa sản phẩm.");
                    }
                }
            });
        }
    </script>
}

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h1>XEM CHI TIẾT</h1>

<div>
    <h4>Sản phẩm</h4>
    <hr />
    
    <div class="row mb-4" id="imageGallery">
        <!-- Load hình ảnh qua jS -->
    </div>

    <dl class="row">
        <dt class="col-sm-2">Tên sản phẩm</dt>
        <dd class="col-sm-10" id="detailName">Loading...</dd>
        
        <dt class="col-sm-2">Mô tả</dt>
        <dd class="col-sm-10" id="detailDesc">Loading...</dd>
        
        <dt class="col-sm-2">Đơn giá</dt>
        <dd class="col-sm-10" id="detailPrice">Loading...</dd>
        
        <dt class="col-sm-2">Trạng thái</dt>
        <dd class="col-sm-10" id="detailStatus">Loading...</dd>
        
        <dt class="col-sm-2">Sản phẩm theo loại</dt>
        <dd class="col-sm-10" id="detailType">Loading...</dd>
    </dl>
</div>
<div>
    <div style="float: left; padding-right:10px">
        <!-- Nút sửa sẽ được update href bằng JS -->
        <a class="btn btn-primary" id="btnEdit" href="#">Sửa</a>
    </div>
    <a class="btn btn-secondary" asp-action="Index">Quay Lại</a>
</div>

<!-- Lấy ID truyền từ route MVC qua View -->
<input type="hidden" id="ProductId" value="@ViewContext.RouteData.Values["id"]" />

@section Scripts {
    <script>
        $(document).ready(function () {
            var id = $('#ProductId').val();
            if(!id) return;

            $.ajax({
                url: '/api/products/' + id,
                type: 'GET',
                success: function (res) {
                    $('#detailName').text(res.name);
                    $('#detailDesc').text(res.description || 'Không có mô tả');
                    
                    var price = res.price ? res.price.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }) : '0 ₫';
                    $('#detailPrice').text(price);
                    
                    $('#detailStatus').text(res.status === 1 ? 'Còn hoạt động' : 'Ngừng hoạt động');
                    $('#detailType').text(res.productTypeName || '');
                    
                    $('#btnEdit').attr("href", "/Admin/Products/Edit/" + res.id);

                    // Load gallery
                    if(res.imageUrls && res.imageUrls.length > 0) {
                        var htmlImg = "";
                        res.imageUrls.forEach(function(url) {
                            htmlImg += '<img src="/contents/Images/Product/' + url + '" style="width: 200px; height: 200px; border-radius: 20px; object-fit: cover; margin-right:10px" alt="Product Image" />';
                        });
                        $('#imageGallery').html(htmlImg);
                    }
                },
                error: function (err) {
                    alert('Lỗi khi tải thông tin sản phẩm từ hệ thống.');
                }
            });
        });
    </script>
}
